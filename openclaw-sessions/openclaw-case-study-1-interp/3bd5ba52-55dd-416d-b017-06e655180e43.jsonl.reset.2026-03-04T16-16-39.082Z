card__note\">{computeTarget}</p>\n      </article>\n      <article className=\"runtime-card\">\n        <h3>Prompt snapshot</h3>\n        <p>{lastPrompt || 'Awaiting input...'}</p>\n        <small>{tokens ? `${tokens} tokens parsed` : 'No tokens yet'}</small>\n        <p className=\"runtime-card__note\">Warm up the circuit to log activations.</p>\n      </article>\n      <article className=\"runtime-card\">\n        <h3>Patch summary</h3>\n        <p>{patchSummary}</p>\n        <small>Interventions are ephemeral and replayable.</small>\n      </article>\n    </section>\n  )\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/components/RuntimeOverview.tsx\",\"content\":\"import { useModelRuntime } from '../runtime/modelRuntime'\\n\\nexport function RuntimeOverview() {\\n  const { modelName, modelSize, computeTarget, tokens, lastPrompt, patchSummary } = useModelRuntime()\\n  return (\\n    <section className=\\\"runtime-grid runtime-overview\\\">\\n      <article className=\\\"runtime-card\\\">\\n        <h3>Runtime target</h3>\\n        <p>{modelName}</p>\\n        <small>{modelSize}</small>\\n        <p className=\\\"runtime-card__note\\\">{computeTarget}</p>\\n      </article>\\n      <article className=\\\"runtime-card\\\">\\n        <h3>Prompt snapshot</h3>\\n        <p>{lastPrompt || 'Awaiting input...'}</p>\\n        <small>{tokens ? `${tokens} tokens parsed` : 'No tokens yet'}</small>\\n        <p className=\\\"runtime-card__note\\\">Warm up the circuit to log activations.</p>\\n      </article>\\n      <article className=\\\"runtime-card\\\">\\n        <h3>Patch summary</h3>\\n        <p>{patchSummary}</p>\\n        <small>Interventions are ephemeral and replayable.</small>\\n      </article>\\n    </section>\\n  )\\n}\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.1-codex-mini","usage":{"input":502,"output":325,"cacheRead":31232,"cacheWrite":0,"totalTokens":32059,"cost":{"input":0.0001255,"output":0.00065,"cacheRead":0.0007