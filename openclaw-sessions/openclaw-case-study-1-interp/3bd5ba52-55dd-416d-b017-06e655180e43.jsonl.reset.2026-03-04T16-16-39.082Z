e TextGenerationPipelineCallback = (texts: string | string[] | Chat | Chat[], options?: TextGenerationConfig) => Promise<TextGenerationOutput | TextGenerationOutput[]>;\n1715:export type TextGenerationPipelineType = TextPipelineConstructorArgs & TextGenerationPipelineCallback & Disposable;\n2230:        pipeline: typeof Text2TextGenerationPipeline;\n2239:        pipeline: typeof TextGenerationPipeline;"}],"details":{"status":"completed","exitCode":0,"durationMs":14,"aggregated":"26: *  - `\"text2text-generation\"`: will return a `Text2TextGenerationPipeline`.\n28: *  - `\"text-generation\"`: will return a `TextGenerationPipeline`.\n301:declare const Text2TextGenerationPipeline_base: new (options: TextPipelineConstructorArgs) => Text2TextGenerationPipelineType;\n307: * @callback Text2TextGenerationPipelineCallback Generate the output text(s) using text(s) given as inputs.\n312: * @typedef {TextPipelineConstructorArgs & Text2TextGenerationPipelineCallback & Disposable} Text2TextGenerationPipelineType\n315: * Text2TextGenerationPipeline class for generating text using a model that performs text-to-text generation tasks.\n326:export class Text2TextGenerationPipeline extends Text2TextGenerationPipeline_base {\n345: * A pipeline for summarization tasks, inheriting from Text2TextGenerationPipeline.\n430:declare const TextGenerationPipeline_base: new (options: TextPipelineConstructorArgs) => TextGenerationPipelineType;\n443: * @callback TextGenerationPipelineCallback Complete the prompt(s) given as inputs.\n448: * @typedef {TextPipelineConstructorArgs & TextGenerationPipelineCallback & Disposable} TextGenerationPipelineType\n500:export class TextGenerationPipeline extends TextGenerationPipeline_base {\n1413:    \"text2text-generation\": Text2TextGenerationPipeline;\n1414:    \"text-generation\": TextGenerationPipeline;\n1663:export type Text2TextGenerationPipelineCallback = (texts: string | string[], options?: import('./utils/generation.js').GenerationConfigType) => Promise