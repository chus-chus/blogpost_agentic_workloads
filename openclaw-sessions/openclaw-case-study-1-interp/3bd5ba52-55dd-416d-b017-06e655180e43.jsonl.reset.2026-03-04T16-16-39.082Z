 const value = values[i]\n    if (buffer.length < count) {\n      buffer.push({ id: i, value })\n      if (buffer.length === count) {\n        buffer.sort((a, b) => a.value - b.value)\n      }\n      continue\n    }\n    if (value > buffer[0].value) {\n      buffer[0] = { id: i, value }\n      buffer.sort((a, b) => a.value - b.value)\n    }\n  }\n  return buffer.sort((a, b) => b.value - a.value)\n}\n\nconst buildCircuitGraph = (activations: ActivationEntry[]) => {\n","newText":"const selectTopIndices = (values: Float32Array, count: number) => {\n  const buffer: Array<{ id: number; value: number }> = []\n  for (let i = 0; i < values.length; i += 1) {\n    const value = values[i]\n    if (buffer.length < count) {\n      buffer.push({ id: i, value })\n      if (buffer.length === count) {\n        buffer.sort((a, b) => a.value - b.value)\n      }\n      continue\n    }\n    if (value > buffer[0].value) {\n      buffer[0] = { id: i, value }\n      buffer.sort((a, b) => a.value - b.value)\n    }\n  }\n  return buffer.sort((a, b) => b.value - a.value)\n}\n\nconst createMechanisticInsights = (activations: ActivationEntry[], tokenCount: number): MechanisticMetric[] => {\n  const techniques: MechanisticMetric['technique'][] = ['activation patching', 'circuit probing', 'causal scrubbing']\n  return activations.slice(0, techniques.length).map((activation, index) => ({\n    id: `${activation.neuron}-${index}`,\n    focus: activation.neuron,\n    technique: techniques[index],\n    description: `Focuses on ${activation.layer ?? 'layered'} ${activation.head ?? 'signals'} with a logit swing of ${activation.impact}.`,\n    evidence: `Top ${index + 1} contributor among ${tokenCount} tokens (avg logit delta: ${activation.impact.toFixed(1)}).`,\n    value: Number(activation.impact.toFixed(1)),\n  }))\n}\n\nconst buildCircuitGraph = (activations: ActivationEntry[]) => {\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/runtime/transformerRunner.ts\",\"oldText\":\"const selectTopIndices = 