ction-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 1rem;\n}\n\n.mechanistic-panel {\n  background: #0f172a;\n  border-radius: 20px;\n  padding: 2rem;\n  border: 1px solid rgba(255, 255, 255, 0.1);\n  color: white;\n  box-shadow: 0 20px 35px rgba(15, 23, 42, 0.5);\n}\n\n.mechanistic-grid {\n  margin-top: 1rem;\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));\n  gap: 1rem;\n}\n\n.mechanistic-card {\n  background: rgba(15, 23, 42, 0.75);\n  border-radius: 16px;\n  padding: 1.2rem;\n  border: 1px solid rgba(148, 163, 184, 0.3);\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.mechanistic-card__header {\n  display: flex;\n  flex-direction: column;\n  gap: 0.15rem;\n}\n\n.mechanistic-card__label {\n  font-size: 0.85rem;\n  text-transform: uppercase;\n  letter-spacing: 0.2rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.mechanistic-card__focus {\n  margin: 0;\n  font-size: 1.1rem;\n}\n\n.mechanistic-card__description,\n.mechanistic-card__evidence,\n.mechanistic-card__value {\n  margin: 0;\n  font-size: 0.9rem;\n  color: rgba(255, 255, 255, 0.7);\n}\n\n.mechanistic-progress {\n  width: 100%;\n  height: 6px;\n  background: rgba(148, 163, 184, 0.25);\n  border-radius: 999px;\n  overflow: hidden;\n}\n\n.mechanistic-progress__fill {\n  height: 100%;\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/App.css\",\"oldText\":\"\\n.inspection-grid {\\n  display: grid;\\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\\n  gap: 1rem;\\n}\\n\",\"newText\":\"\\n.inspection-grid {\\n  display: grid;\\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\\n  gap: 1rem;\\n}\\n\\n.mechanistic-panel {\\n  background: #0f172a;\\n  border-radius: 20px;\\n  padding: 2rem;\\n  border: 1px solid rgba(255, 255, 255, 0.1);\\n  color: white;\\n  box-shadow: 0 20px 35px rgba(15, 23, 42, 0.5);\\n}\\n\\n.mechanistic-grid {\\n  margin-top: 1rem;\\n  display: grid;\\n  grid-tem