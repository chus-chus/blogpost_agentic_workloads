ows', async ({ page }) => {\n    await expect(page.getByRole('heading', { name: 'Activation highlights' })).toBeVisible()\n    await expect(page.locator(SELECTORS.activationList)).toHaveCount(3)\n    await expect(page.locator('text=Streaming logits from the last token')).toBeVisible()\n  })\n\n  test('shows the circuit graph sketch with controls', async ({ page }) => {\n    await expect(page.getByRole('heading', { name: 'Circuit graph sketch' })).toBeVisible()\n    await expect(page.locator(SELECTORS.graphCanvas)).toBeVisible()\n    await expect(page.locator(SELECTORS.controls)).toBeVisible()\n  })\n})\n","newText":"import { expect, test } from '@playwright/test'\n\nconst SELECTORS = {\n  activationList: '.activation-row',\n  graphCanvas: '.graph-wrapper .react-flow',\n  controls: '.react-flow__controls',\n  patchSummary: '.patch-summary',\n  mechanisticCard: '.mechanistic-card',\n}\n\ntest.describe('Interpretability panels', () => {\n  test.beforeEach(async ({ page }) => {\n    await page.goto('/')\n  })\n\n  test('renders the activation highlights panel with sample rows', async ({ page }) => {\n    await expect(page.getByRole('heading', { name: 'Activation highlights' })).toBeVisible()\n    await expect(page.locator(SELECTORS.activationList)).toHaveCount(3)\n    await expect(page.locator('text=Streaming logits from the last token')).toBeVisible()\n  })\n\n  test('shows the circuit graph sketch with controls', async ({ page }) => {\n    await expect(page.getByRole('heading', { name: 'Circuit graph sketch' })).toBeVisible()\n    await expect(page.locator(SELECTORS.graphCanvas)).toBeVisible()\n    await expect(page.locator(SELECTORS.controls)).toBeVisible()\n  })\n\n  test('applies a patch and updates the summary', async ({ page }) => {\n    const patchSummary = page.locator(SELECTORS.patchSummary)\n    await expect(patchSummary).toContainText('Standby')\n    await page.locator('.patch-control-panel button.primary').click()\n    await expect(patchSummary).toContainText('Applied')\n  })\n\n  test('shows mechanistic interpretability insights', async ({ page }) => {\n    await expect(page.getByRole('heading', { name: 'Triangulate the causal circuitry.' })).toBeVisible()\n    await expect(page.locator(SELECTORS.mechanisticCard)).toHaveCount(3)\n  })\n})\n"},"partialJson":"{\"path\":\"visual-llm-ui/playwright/tests/interpretability-panels.spec.ts\",\"oldText\":\"import { expect, test } from '@playwright/test'\\n\\nconst SELECTORS = {\\n  activationList: '.activation-row',\\n  graphCanvas: '.graph-wrapper .react-flow',\\n  controls: '.react-flow__controls',\\n}\\n\\ntest.describe('Interpretability panels', () => {\\n  test.beforeEach(async ({ page }) => {\\n    await page.goto('/')\\n  })\\n\\n  test('renders the activation highlights panel with sample rows', async ({ page }) => {\\n    await expect(page.getByRole('heading', { name: 'Activation highlights' })).toBeVisible()\\n    await expect(page.locator(SELECTORS.activationList)).toHaveCount(3)\\n    await expect(page.locator('text=Streaming logits from the last token')).toBeVisible()\\n  })\\n\\n  test('shows the circuit graph sketch with controls', async ({ page }) => {\\n    await expect(page.getByRole('heading', { name: 'Circuit graph sketch' })).toBeVisible()\\n    await expect(page.locator(SELECTORS.graphCanvas)).toBeVisible()\\n    await expect(page.locator(SELECTORS.controls)).toBeVisible()\\n  })\\n})\\n\",\"newText\":\"import { expect, test } from '@playwright/test'\\n\\nconst SELECTORS = {\\n  activationList: '.activation-row',\\n  graphCanvas: '.graph-wrapper .react-flow',\\n  controls: '.react-flow__controls',\\n  patchSummary: '.patch-summary',\\n  mechanisticCard: '.mechanistic-card',\\n}\\n\\ntest.describe('Interpretability panels', () => {\\n  test.beforeEach(async ({ page }) => {\\n    await page.goto('/')\\n  })\\n\\n  test('renders the activation highlights panel with sample rows', async ({ page }) => {\\n    await expect(page.getByRole('heading', { name: 'Activation highlights' })).toBeVisible()\\n    await expect(page.locator(SELECTORS.activationList)).toHaveCount(3)\\n    await expect(page.locator('text=Streaming logits from the last token')).toBeVisible()\\n  })\\n\\n  test('shows the circuit graph sketch with controls', async ({ page }) => {\\n    await expect(page.getByRole('heading', { name: 'Circuit graph sketch' })).toBeVisible()\\n    await expect(page.locator(SELECTORS.graphCanvas)).toBeVisible()\\n    await expect(page.locator(SELECTORS.controls)).toBeVisible()\\n  })\\n\\n  test('applies a patch and updates the summary', async ({ page }) => {\\n    const patchSummary = page.locator(SELECTORS.patchSummary)\\n    await expect(patchSummary).toContainText('Standby')\\n    await page.locator('.patch-control-panel button.primary').click()\\n    await expect(patchSummary).toContainText('Applied')\\n  })\\n\\n  test('shows mechanistic interpretability insights', async ({ page }) => {\\n    await expect(page.getByRole('heading', { name: 'Triangulate the causal circuitry.' })).toBeVisible()\\n    await expect(page.locator(SELECTORS.mechanisticCard)).toHaveCount(3)\\n  })\\n})\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.1-codex-mini","usage":{"input":161,"output":1083,"cacheRead":102016,"cacheWrite":0,"totalTokens":103260,"cost":{"input":0.000040249999999999996,"output":0.002166,"cacheRead":0.0025504000000000004,"cacheWrite":0,"total":0.00475665}},"stopReason":"toolUse","timestamp":1772624368852}}
