{"type":"message","id":"68786181","parentId":"ef62cae8","timestamp":"2026-03-04T11:25:29.644Z","message":{"role":"toolResult","toolCallId":"call_NCewfNMTKQ7o8mEdgmiUjvjG|fc_044be20a9efe26f90169a816a946148191a20339de30a5adcf","toolName":"read","content":[{"type":"text","text":"import { useState } from 'react'\nimport type { FormEvent } from 'react'\n\nexport interface PromptControlProps {\n  label?: string\n  placeholder?: string\n  defaultValue?: string\n  onSubmit?: (prompt: string) => void\n}\n\nexport function PromptControl({\n  label = 'Prompt',\n  placeholder = 'Type a prompt to inspect',\n  defaultValue = '',\n  onSubmit,\n}: PromptControlProps) {\n  const [prompt, setPrompt] = useState(defaultValue)\n\n  const handleSubmit = (event: FormEvent<HTMLFormElement>) => {\n    event.preventDefault()\n    onSubmit?.(prompt.trim())\n  }\n\n  return (\n    <form className=\"prompt-control\" onSubmit={handleSubmit}>\n      <label className=\"prompt-control__label\" htmlFor=\"prompt-input\">\n        {label}\n      </label>\n      <div className=\"prompt-control__field\">\n        <input\n          id=\"prompt-input\"\n          className=\"prompt-control__input\"\n          placeholder={placeholder}\n          value={prompt}\n          onChange={(event) => setPrompt(event.target.value)}\n        />\n        <button type=\"submit\" className=\"prompt-control__button\">\n          Run\n        </button>\n      </div>\n    </form>\n  )\n}\n"}],"isError":false,"timestamp":1772623529640}}
