{"type":"message","id":"45e12a23","parentId":"6561f5a8","timestamp":"2026-03-04T11:37:27.003Z","message":{"role":"toolResult","toolCallId":"call_cCn4gL6zsNLybOpzfLCCH4T9|fc_044be20a9efe26f90169a81976dc1481919041208e191a834c","toolName":"read","content":[{"type":"text","text":"import type { Edge, Node } from 'reactflow'\nimport type { ActivationEntry, MechanisticMetric, ScrubRun } from '../types/activation'\nimport type { FeatureExtractionPipeline } from '@xenova/transformers/types/pipelines'\nimport type { DataArray } from '@xenova/transformers/types/utils/tensor'\n\nconst MODEL_ID = 'Xenova/distilgpt2'\nconst TOP_K = 4\n\nconst toFloat32Array = (data: DataArray) => {\n  if (data instanceof Float32Array) {\n    return data\n  }\n  const normalized = Array.from(data as Iterable<number | bigint>, (value) => Number(value))\n  return Float32Array.from(normalized)\n}\n\nlet extractorPromise: Promise<FeatureExtractionPipeline> | null = null\nlet featureExtractor: FeatureExtractionPipeline | null = null\n\nconst loadFeatureExtractor = async () => {\n  if (featureExtractor) {\n    return featureExtractor\n  }\n  if (!extractorPromise) {\n    extractorPromise = (async () => {\n      const { pipeline } = await import('@xenova/transformers')\n      return pipeline('feature-extraction', MODEL_ID, { quantized: true })\n    })()\n  }\n  featureExtractor = await extractorPromise\n  return featureExtractor\n}\n\nconst selectTopIndices = (values: Float32Array, count: number) => {\n  const buffer: Array<{ id: number; value: number }> = []\n  for (let i = 0; i < values.length; i += 1) {\n    const value = values[i]\n    if (buffer.length < count) {\n      buffer.push({ id: i, value })\n      if (buffer.length === count) {\n        buffer.sort((a, b) => a.value - b.value)\n      }\n      continue\n    }\n    if (value > buffer[0].value) {\n      buffer[0] = { id: i, value }\n      buffer.sort((a, b) => a.value - b.value)\n    }\n  }\n  return buffer.sort((a, b) => b.value - a.value)\n}\n\nconst buildCircuitGraph = (activations: ActivationEntry[]) => {\n  const embeddingNode: Node = {\n    id: 'embedding',\n    data: { label: 'Embedding', signal: 64, status: 'balanced' },\n    position: { x: 0, y: 0 },\n  }\n\n  const residualNode: Node = {\n    id: 'residual-add',\n    data: { label: 'Residual add', signal: 78, status: 'dominant' },\n    position: { x: 360, y: 40 },\n  }\n\n  const logitsNode: Node = {\n    id: 'logits',\n    data: { label: 'Logits', signal: 92, status: 'dominant' },\n    position: { x: 520, y: 40 },\n  }\n\n  const tokenNodes: Node[] = activations.map((activation, index) => ({\n    id: `token-${index}`,\n    data: {\n      label: `${index + 1}. ${activation.neuron}`,\n      signal: Math.round(70 + Math.abs(activation.impact) * 4),\n      status: activation.impact >= 0 ? 'dominant' : 'balanced',\n    },\n    position: { x: 180, y: index * 90 - 30 },\n  }))\n\n  const nodes = [embeddingNode, ...tokenNodes, residualNode, logitsNode]\n\n  const tokenEdges: Edge[] = tokenNodes.flatMap((node, index) => [\n    {\n      id: `e-embedding-${node.id}`,\n      source: 'embedding',\n      target: node.id,\n      animated: index % 2 === 0,\n    },\n    {\n      id: `e-${node.id}-residual`,\n      source: node.id,\n      target: residualNode.id,\n      animated: true,\n    },\n  ])\n\n  const edges: Edge[] = [\n    ...tokenEdges,\n    { id: 'e-residual-logits', source: residualNode.id, target: logitsNode.id, animated: true },\n  ]\n\n  return { nodes, edges }\n}\n\nexport interface PromptInferenceResult {\n  activations: ActivationEntry[]\n  circuitNodes: Node[]\n  circuitEdges: Edge[]\n  scrubRuns: ScrubRun[]\n  patchSummary: string\n  tokenCount: number\n}\n\nexport async function runPromptThroughModel(prompt: string): Promise<PromptInferenceResult> {\n  const extractor = await loadFeatureExtractor()\n  const tokenizerOutput = extractor.tokenizer(prompt, {\n    return_tensor: false,\n    truncation: true,\n    padding: false,\n  })\n\n  const tokenCount = Array.isArray(tokenizerOutput.input_ids)\n    ? tokenizerOutput.input_ids.length\n    : tokenizerOutput.input_ids[0]?.length ?? prompt.split(' ').length\n\n  const tensor = await extractor(prompt, {\n    pooling: 'none',\n  })\n\n  const [, seqLen, vocabSize] = tensor.dims\n  const dataArray = toFloat32Array(tensor.data)\n  const lastTokenStart = Math.max(0, (seqLen - 1) * vocabSize)\n  const logits = dataArray.subarray(lastTokenStart, lastTokenStart + vocabSize)\n  const avgLogit = logits.reduce((sum, value) => sum + value, 0) / logits.length\n\n  const top = selectTopIndices(logits, TOP_K)\n  if (!top.length) {\n    throw new Error('Unable to extract activations from the model response.')\n  }\n\n  const activations: ActivationEntry[] = top.map(({ id, value }, index) => {\n    const decoded = extractor.tokenizer.decode([id], {\n      skip_special_tokens: true,\n      clean_up_tokenization_spaces: true,\n    })\n    const neuron = decoded?.trim() || `Token ${id}`\n    return {\n      neuron,\n      impact: Number(((value - avgLogit) / 4).toFixed(1)),\n      note: `Logit delta vs. baseline: ${Number((value - avgLogit).toFixed(1))}`,\n      layer: `Layer ${((index % 6) + 1) * 2}`,\n      head: `Head ${((index % 12) + 1)}`,\n    }\n  })\n\n  const { nodes, edges } = buildCircuitGraph(activations)\n  const scrubRuns: ScrubRun[] = activations.map((activation, index) => ({\n    id: `${prompt}-${index}-${activation.neuron}`,\n    label: `Scrub ${activation.neuron}`,\n    logitShift: activation.impact,\n    summary: activation.impact >= 0 ? 'Elevation in the target logit' : 'Suppression ripple detected',\n    policy: index === 0 ? 'replace' : index === 1 ? 'mix' : 'zero',\n    timestamp: new Date().toISOString(),\n  }))\n\n  const patchSummary = `Patch loop aligned with ${activations[0].neuron}.`\n\n  return {\n    activations,\n    circuitNodes: nodes,\n    circuitEdges: edges,\n    scrubRuns,\n    patchSummary,\n    tokenCount,\n  }\n}\n"}],"isError":false,"timestamp":1772624246999}}
