04);\n}\n\n.prompt-control__label {\n  font-size: 0.85rem;\n  text-transform: uppercase;\n  letter-spacing: 0.2rem;\n  color: #4c1d95;\n}\n\n.prompt-control__field {\n  display: flex;\n  gap: 0.5rem;\n}\n\n.prompt-control__input {\n  flex: 1;\n  border: 1px solid rgba(15, 23, 42, 0.15);\n  border-radius: 999px;\n  padding: 0.7rem 1.25rem;\n  font-size: 1rem;\n}\n\n.prompt-control__button {\n  border-radius: 999px;\n  padding: 0.75rem 1.5rem;\n  border: none;\n  background: #4c1d95;\n  color: white;\n  font-weight: 600;\n  cursor: pointer;\n}\n\n.activations-panel__matrix {\n  margin-top: 1.5rem;\n}\n\n.activations-matrix {\n  border-radius: 16px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  display: flex;\n  flex-direction: column;\n  gap: 0.4rem;\n  background: rgba(15, 23, 42, 0.15);\n}\n\n.activations-matrix__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.9rem 1rem;\n  border-radius: 12px;\n  background: rgba(15, 23, 42, 0.25);\n}\n\n.activations-matrix__row--negative {\n  background: rgba(244, 114, 182, 0.15);\n}\n\n.activations-matrix__row--positive {\n  background: rgba(34, 197, 94, 0.15);\n}\n\n.activations-matrix__neuron {\n  font-weight: 600;\n}\n\n.activations-matrix__impact {\n  font-weight: 700;\n  color: #fdfdfd;\n  min-width: 60px;\n  text-align: right;\n}\n\n.activations-matrix__note {\n  font-size: 0.85rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n","newText":"@media (max-width: 640px) {\n  .hero {\n    padding: 2.2rem;\n  }\n\n  .hero-actions {\n    flex-direction: column;\n  }\n}\n\n.prompt-panel {\n  background: #ffffff;\n  border-radius: 20px;\n  padding: 1.5rem;\n  border: 1px solid rgba(15, 23, 42, 0.07);\n  box-shadow: 0 15px 35px rgba(15, 23, 42, 0.06);\n  display: flex;\n  flex-direction: column;\n  gap: 0.75rem;\n}\n\n.prompt-panel__status {\n  margin: 0;\n  color: rgba(15, 23, 42, 0.7);\n  font-size: 0.95rem;\n}\n\n.prompt-control {\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n  border-radius: 14px;\n  padding: 1rem;\n  border: 1px solid rgba(99, 102, 241, 0.3);\n  background: rgba(99, 102, 241, 0.04);\n}\n\n.prompt-control__label {\n  font-size: 0.85rem;\n  text-transform: uppercase;\n  letter-spacing: 0.2rem;\n  color: #4c1d95;\n}\n\n.prompt-control__field {\n  display: flex;\n  gap: 0.5rem;\n}\n\n.prompt-control__input {\n  flex: 1;\n  border: 1px solid rgba(15, 23, 42, 0.15);\n  border-radius: 999px;\n  padding: 0.7rem 1.25rem;\n  font-size: 1rem;\n}\n\n.prompt-control__button {\n  border-radius: 999px;\n  padding: 0.75rem 1.5rem;\n  border: none;\n  background: #4c1d95;\n  color: white;\n  font-weight: 600;\n  cursor: pointer;\n}\n\n.activations-panel__matrix {\n  margin-top: 1.5rem;\n}\n\n.activations-matrix {\n  border-radius: 16px;\n  overflow: hidden;\n  border: 1px solid rgba(255, 255, 255, 0.15);\n  display: flex;\n  flex-direction: column;\n  gap: 0.4rem;\n  background: rgba(15, 23, 42, 0.15);\n}\n\n.activations-matrix__row {\n  display: flex;\n  justify-content: space-between;\n  align-items: center;\n  padding: 0.9rem 1rem;\n  border-radius: 12px;\n  background: rgba(15, 23, 42, 0.25);\n}\n\n.activations-matrix__row--negative {\n  background: rgba(244, 114, 182, 0.15);\n}\n\n.activations-matrix__row--positive {\n  background: rgba(34, 197, 94, 0.15);\n}\n\n.activations-matrix__neuron {\n  font-weight: 600;\n}\n\n.activations-matrix__impact {\n  font-weight: 700;\n  color: #fdfdfd;\n  min-width: 60px;\n  text-align: right;\n}\n\n.activations-matrix__note {\n  font-size: 0.85rem;\n  color: rgba(255, 255, 255, 0.6);\n}\n\n.inspection-grid {\n  display: grid;\n  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));\n  gap: 1rem;\n}\n\n.patch-control-panel,\n.scrub-timeline {\n  display: flex;\n  flex-direction: column;\n  gap: 1rem;\n}\n\n.patch-control-panel select,\n.patch-control-panel input[type='range'] {\n  width: 100%;\n  margin-top: 0.5rem;\n}\n\n.patch-control-panel label {\n  display: flex;\n  flex-direction: column;\n  gap: 0.25rem;\n  font-size: 0.85rem;\n  color: rgba(255, 255, 255, 0.8);\n}\n\n.patch-modes {\n  display: flex;\n  gap: 0.5rem;\n  flex-wrap: wrap;\n}\n\n.patch-modes button {\n  flex: 1;\n  border-radius: 12px;\n  padding: 0.65rem 1rem;\n  border: 1px solid rgba(255, 255, 255, 0.4);\n  background: transparent;\n  color: white;\n}\n\n.patch-modes button.is-active {\n  background: rgba(59, 130, 246, 0.3);\n  border-color: rgba(59, 130, 246, 0.8);\n}\n\n.intensity-slider {\n  display: flex;\n  flex-direction: column;\n  gap: 0.35rem;\n}\n\n.patch-control-panel .patch-summary {\n  margin: 0;\n  color: rgba(255, 255, 255, 0.7);\n  font-size: 0.9rem;\n}\n\n.scrub-list {\n  display: flex;\n  flex-direction: column;\n  gap: 0.85rem;\n}\n\n.scrub-row {\n  border-radius: 14px;\n  padding: 0.9rem 1rem;\n  background: rgba(51, 65, 85, 0.7);\n  display: flex;\n  flex-direction: column;\n  gap: 0.5rem;\n}\n\n.scrub-row__meta {\n  display: flex;\n  flex-direction: column;\n  gap: 0.1rem;\n}\n\n.scrub-row__label {\n  margin: 0;\n  font-weight: 600;\n}\n\n.scrub-row__summary {\n  margin: 0;\n  color: rgba(226, 232, 240, 0.7);\n  font-size: 0.85rem;\n}\n\n.scrub-row__bar {\n  height: 8px;\n  border-radius: 999px;\n  background: rgba(148, 163, 184, 0.4);\n  overflow: hidden;\n}\n\n.scrub-row__bar-fill {\n  height: 100%;\n  border-radius: 999px;\n}\n\n.scrub-row__actions {\n  display: flex;\n  align-items: center;\n  justify-content: space-between;\n}\n\n.scrub-row__value {\n  font-weight: 700;\n  font-size: 0.95rem;\n}\n\n.scrub-row button {\n  background: rgba(255, 255, 255, 0.1);\n  color: white;\n  border: none;\n  border-radius: 999px;\n  padding: 0.4rem 1rem;\n  cursor: pointer;\n}\n\n.circuit-inspector {\n  margin-top: 1.5rem;\n  border-radius: 16px;\n  padding: 1.25rem;\n  background: rgba(15, 23, 42, 0.65);\n  border: 1px solid rgba(255, 255, 255, 0.1);\n}\n\n.circuit-inspector__stats {\n  display: grid;\n  grid-template-columns: repeat(2, minmax(0, 1fr));\n  gap: 0.75rem;\n}\n\n.circuit-inspector__stats p {\n  margin: 0;\n  font-size: 0.95rem;\n  color: rgba(255, 255, 255, 0.75);\n}\n\n.circuit-inspector__stats span {\n  display: block;\n  font-size: 0.75rem;\n  text-transform: uppercase;\n  letter-spacing: 0.18rem;\n  color: rgba(255, 255, 255, 0.55);\n}\n\n.circuit-inspector__stats strong {\n  display: block;\n  font-size: 1.3rem;\n}\n\n.circuit-inspector__pills {\n  margin-top: 1rem;\n  display: flex;\n  flex-wrap: wrap;\n  gap: 0.5rem;\n}\n\n.circuit-inspector__pills button {\n  border-radius: 999px;\n  padding: 0.4rem 0.9rem;\n  border: 1px solid rgba(255, 255, 255, 0.2);\n  background: transparent;\n  color: rgba(255, 255, 255, 0.75);\n}\n\n.circuit-inspector__pills button.is-active {\n  border-color: rgba(16, 185, 129, 0.7);\n  color: #10b981;\n}\n\n.runtime-overview {\n  margin-top: 1rem;\n}\n\n.runtime-card__note {\n  margin-top: 1rem;\n  color: rgba(15, 23, 42, 0.7);\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/App.css\",\"oldText\":\"@media (max-width: 640px) {\\n  .hero {\\n    padding: 2.2rem;\\n  }\\n\\n  .hero-actions {\\n    flex-direction: column;\\n  }\\n}\\n\\n.prompt-panel {\\n  background: #ffffff;\\n  border-radius: 20px;\\n  padding: 1.5rem;\\n  border: 1px solid rgba(15, 23, 42, 0.07);\\n  box-shadow: 0 15px 35px rgba(15, 23, 42, 0.06);\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.75rem;\\n}\\n\\n.prompt-panel__status {\\n  margin: 0;\\n  color: rgba(15, 23, 42, 0.7);\\n  font-size: 0.95rem;\\n}\\n\\n.prompt-control {\\n  display: flex;\\n  flex-direction: column;\\n  gap: 0.5rem;\\n  border-radius: 14px;\\n  padding: 1rem;\\n  border: 1px solid rgba(99, 102, 241, 0.3);\\n  background: rgba(99, 102, 241, 0.04);\\n}\\n\\n.prompt-control__label {\\n  font-size: 0.85rem;\\n  text-transform: uppercase;\\n  letter-spacing: 0.2rem;\\n  color: #4c1d95;\\n}\\n\\n.prompt-control__field {\\n  display: flex;\\n  gap: 0.5rem;\\n}\\n\\n.prompt-control__input {\\n  fl