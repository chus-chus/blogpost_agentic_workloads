{"type":"message","id":"d195d529","parentId":"b19b89bd","timestamp":"2026-03-04T11:25:27.074Z","message":{"role":"toolResult","toolCallId":"call_KkeoT4s0W7lhuW5PUYfp7SWn|fc_044be20a9efe26f90169a816a640f08191be53ac416f6eb9da","toolName":"read","content":[{"type":"text","text":"import './App.css'\nimport ReactFlow, { Background, Controls } from 'reactflow'\nimport 'reactflow/dist/style.css'\nimport { useState } from 'react'\n\nimport { ActivationsMatrix } from './components/ActivationsMatrix'\nimport type { ActivationEntry } from './components/ActivationsMatrix'\nimport { PromptControl } from './components/PromptControl'\n\nconst featureCards = [\n  {\n    title: 'Activation patching lounge',\n    description:\n      'Show candidate neurons, layerwise activations, and patching experiments in real time with hooks for alternate prompts.',\n  },\n  {\n    title: 'Circuit topology canvas',\n    description:\n      'Compose directed graphs with React Flow to trace attribution through attention heads, MLPs, and residual streams.',\n  },\n  {\n    title: 'Causal scrubbing studio',\n    description:\n      'Replay interventions, swap on- and off-path activations, and compare logit trajectories for different scrubbing policies.',\n  },\n]\n\nconst runtimeTargets = [\n  {\n    title: 'M1 Pro + Metal',\n    body: 'Quantized ONNX + Core ML exec repr for 4-bit Llama variants, keeping inference times under 80 ms per batch.',\n  },\n  {\n    title: 'Browser-native engine',\n    body: 'WebGPU + WebAssembly runtimes run distilled Transformers entirely client-side for demos.',\n  },\n  {\n    title: 'Remote fallback',\n    body: 'Optional cloud ops for heavier models, streaming scores back for blended interpretability workflows.',\n  },\n]\n\nconst circuitNodes = [\n  { id: '1', data: { label: 'Embedding' }, position: { x: 0, y: 0 } },\n  { id: '2', data: { label: 'Layer 3 Attn 12' }, position: { x: 180, y: -20 } },\n  { id: '3', data: { label: 'Layer 7 MLP 192' }, position: { x: 180, y: 120 } },\n  { id: '4', data: { label: 'Residual Add' }, position: { x: 360, y: 40 } },\n  { id: '5', data: { label: 'Logits' }, position: { x: 520, y: 40 } },\n]\n\nconst circuitEdges = [\n  { id: 'e1-2', source: '1', target: '2', animated: true },\n  { id: 'e1-3', source: '1', target: '3' },\n  { id: 'e2-4', source: '2', target: '4' },\n  { id: 'e3-4', source: '3', target: '4', animated: true },\n  { id: 'e4-5', source: '4', target: '5' },\n]\n\nconst activationMetrics: ActivationEntry[] = [\n  {\n    neuron: 'Layer 2 attention head 5',\n    impact: 12,\n    note: 'Gate on positive sentiment.',\n  },\n  {\n    neuron: 'Layer 7 MLP neuron 192',\n    impact: -9,\n    note: 'Key visual positional info.',\n  },\n  {\n    neuron: 'Layer 9 residual stream',\n    impact: 6,\n    note: 'Surface-level commonsense bias.',\n  },\n]\n\nconst activationHighlights = activationMetrics.map((metric) => ({\n  label: metric.neuron,\n  value: `${metric.impact > 0 ? '+' : ''}${metric.impact}% impact`,\n  note: metric.note,\n}))\n\nfunction App() {\n  const [lastPrompt, setLastPrompt] = useState('')\n\n  return (\n    <div className=\"app-shell\">\n      <header className=\"hero\">\n        <p className=\"eyebrow\">Browser-first interpretability</p>\n        <h1 data-testid=\"hero-heading\">Visualize transformer mechanics without lifting anything off your MacBook.</h1>\n        <p className=\"hero-subtitle\">\n          Activation patching, causal scrubbing, and circuit graphs layered over lightweight, quantized runtimes\n          keep the investigation on-device—perfect for M1-Pro-powered explorations.\n        </p>\n        <div className=\"hero-actions\">\n          <button className=\"primary\">Launch a live model session</button>\n          <button className=\"ghost\">Browse activation patches</button>\n        </div>\n      </header>\n\n      <section className=\"prompt-panel\">\n        <PromptControl label=\"Inspect prompt\" onSubmit={(value) => setLastPrompt(value)} />\n        <p className=\"prompt-panel__status\">\n          {lastPrompt ? `Last prompt: ${lastPrompt}` : 'Run an input prompt to warm up the circuit scrubber.'}\n        </p>\n      </section>\n\n      <section className=\"feature-grid\">\n        {featureCards.map((card) => (\n          <article key={card.title} className=\"feature-card\">\n            <h3>{card.title}</h3>\n            <p>{card.description}</p>\n          </article>\n        ))}\n      </section>\n\n      <section className=\"panel-grid\">\n        <div className=\"panel activation-panel\">\n          <div className=\"panel-heading\">\n            <h2>Activation highlights</h2>\n            <span>Streaming logits from the last token</span>\n          </div>\n          <div className=\"activation-list\">\n            {activationHighlights.map((row) => (\n              <div key={row.label} className=\"activation-row\">\n                <div>\n                  <p className=\"label\">{row.label}</p>\n                  <p className=\"note\">{row.note}</p>\n                </div>\n                <p className=\"value\">{row.value}</p>\n              </div>\n            ))}\n          </div>\n          <div className=\"activations-panel__matrix\">\n            <ActivationsMatrix activations={activationMetrics} />\n          </div>\n        </div>\n        <div className=\"panel graph-panel\">\n          <div className=\"panel-heading\">\n            <h2>Circuit graph sketch</h2>\n            <span>Animate signal flow between attention heads and MLPs.</span>\n          </div>\n          <div className=\"graph-wrapper\">\n            <ReactFlow nodes={circuitNodes} edges={circuitEdges} fitView fitViewOptions={{ padding: 0.1 }}>\n              <Background gap={18} size={1} />\n              <Controls showInteractive={false} />\n            </ReactFlow>\n          </div>\n        </div>\n      </section>\n\n      <section className=\"runtime-grid\">\n        {runtimeTargets.map((target) => (\n          <article key={target.title} className=\"runtime-card\">\n            <h3>{target.title}</h3>\n            <p>{target.body}</p>\n          </article>\n        ))}\n      </section>\n    </div>\n  )\n}\n\nexport default App\n"}],"isError":false,"timestamp":1772623527069}}
