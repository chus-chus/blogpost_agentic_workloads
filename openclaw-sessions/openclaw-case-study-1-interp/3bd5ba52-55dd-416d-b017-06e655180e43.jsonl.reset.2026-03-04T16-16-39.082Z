nsight.value) * 5)}%`,\n                  background: insight.value >= 0 ? '#34d399' : '#fb7185',\n                }}\n              />\n            </div>\n            <span className=\"mechanistic-card__value\">\n              Value: {insight.value > 0 ? '+' : ''}\n              {insight.value}\n            </span>\n          </article>\n        ))}\n      </div>\n    </section>\n  )\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/components/MechanisticInsights.tsx\",\"content\":\"import { MechanisticMetric } from '../types/activation'\\nimport { useModelRuntime } from '../runtime/modelRuntime'\\n\\nconst techniqueLabels: Record<MechanisticMetric['technique'], string> = {\\n  'activation patching': 'Activation patching experiment',\\n  'circuit probing': 'Circuit probing summary',\\n  'causal scrubbing': 'Causal scrubbing log',\\n}\\n\\nexport function MechanisticInsights() {\\n  const { mechanisticInsights } = useModelRuntime()\\n\\n  if (!mechanisticInsights.length) {\\n    return null\\n  }\\n\\n  return (\\n    <section className=\\\"mechanistic-panel\\\">\\n      <header>\\n        <p className=\\\"eyebrow\\\">Mechanistic interpretability</p>\\n        <h3>Triangulate the causal circuitry.</h3>\\n      </header>\\n      <div className=\\\"mechanistic-grid\\\">\\n        {mechanisticInsights.map((insight) => (\\n          <article key={insight.id} className=\\\"mechanistic-card\\\">\\n            <div className=\\\"mechanistic-card__header\\\">\\n              <span className=\\\"mechanistic-card__label\\\">{techniqueLabels[insight.technique]}</span>\\n              <strong className=\\\"mechanistic-card__focus\\\">{insight.focus}</strong>\\n            </div>\\n            <p className=\\\"mechanistic-card__description\\\">{insight.description}</p>\\n            <p className=\\\"mechanistic-card__evidence\\\">{insight.evidence}</p>\\n            <div className=\\\"mechanistic-progress\\\" aria-hidden>\\n              <div\\n                className=\\\"m