-ui/src/types/activation.ts","oldText":"export interface ActivationEntry {\n  neuron: string\n  impact: number\n  note?: string\n  layer?: string\n  head?: string\n}\n\nexport interface ScrubRun {\n  id: string\n  label: string\n  logitShift: number\n  summary: string\n  policy: 'zero' | 'replace' | 'mix'\n  timestamp: string\n}\n","newText":"export interface ActivationEntry {\n  neuron: string\n  impact: number\n  note?: string\n  layer?: string\n  head?: string\n}\n\nexport interface ScrubRun {\n  id: string\n  label: string\n  logitShift: number\n  summary: string\n  policy: 'zero' | 'replace' | 'mix'\n  timestamp: string\n}\n\nexport type MechanisticTechnique = 'activation patching' | 'circuit probing' | 'causal scrubbing'\n\nexport interface MechanisticMetric {\n  id: string\n  focus: string\n  technique: MechanisticTechnique\n  description: string\n  evidence: string\n  value: number\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/types/activation.ts\",\"oldText\":\"export interface ActivationEntry {\\n  neuron: string\\n  impact: number\\n  note?: string\\n  layer?: string\\n  head?: string\\n}\\n\\nexport interface ScrubRun {\\n  id: string\\n  label: string\\n  logitShift: number\\n  summary: string\\n  policy: 'zero' | 'replace' | 'mix'\\n  timestamp: string\\n}\\n\",\"newText\":\"export interface ActivationEntry {\\n  neuron: string\\n  impact: number\\n  note?: string\\n  layer?: string\\n  head?: string\\n}\\n\\nexport interface ScrubRun {\\n  id: string\\n  label: string\\n  logitShift: number\\n  summary: string\\n  policy: 'zero' | 'replace' | 'mix'\\n  timestamp: string\\n}\\n\\nexport type MechanisticTechnique = 'activation patching' | 'circuit probing' | 'causal scrubbing'\\n\\nexport interface MechanisticMetric {\\n  id: string\\n  focus: string\\n  technique: MechanisticTechnique\\n  description: string\\n  evidence: string\\n  value: number\\n}\\n\"}"}],"api":"openai-codex-responses","provider":"openai-codex","model":"gpt-5.1-codex-mini","u