 <h3>{selectedNode?.data.label}</h3>\n      </header>\n      <div className=\"circuit-inspector__stats\">\n        <p>\n          <span>Signal</span>\n          <strong>{selectedNode?.data.signal ?? '—'}</strong>\n        </p>\n        <p>\n          <span>Role</span>\n          <strong>{selectedNode?.data.status ?? 'balanced'}</strong>\n        </p>\n      </div>\n      <div className=\"circuit-inspector__pills\">\n        {circuitNodes.map((node) => (\n          <button\n            key={node.id}\n            type=\"button\"\n            className={node.id === selectedNodeId ? 'is-active' : ''}\n            onClick={() => selectNode(node.id)}\n          >\n            {node.data.label}\n          </button>\n        ))}\n      </div>\n    </div>\n  )\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/components/CircuitInspector.tsx\",\"content\":\"import type { Node } from 'reactflow'\\nimport { useModelRuntime } from '../runtime/modelRuntime'\\n\\nexport function CircuitInspector() {\\n  const { circuitNodes, selectedNodeId, selectNode } = useModelRuntime()\\n  const selectedNode: Node | undefined = circuitNodes.find((node) => node.id === selectedNodeId) ?? circuitNodes[0]\\n\\n  return (\\n    <div className=\\\"circuit-inspector\\\">\\n      <header>\\n        <p className=\\\"eyebrow\\\">Circuit graph</p>\\n        <h3>{selectedNode?.data.label}</h3>\\n      </header>\\n      <div className=\\\"circuit-inspector__stats\\\">\\n        <p>\\n          <span>Signal</span>\\n          <strong>{selectedNode?.data.signal ?? '—'}</strong>\\n        </p>\\n        <p>\\n          <span>Role</span>\\n          <strong>{selectedNode?.data.status ?? 'balanced'}</strong>\\n        </p>\\n      </div>\\n      <div className=\\\"circuit-inspector__pills\\\">\\n        {circuitNodes.map((node) => (\\n          <button\\n            key={node.id}\\n            type=\\\"button\\\"\\n            className={node.id === selectedNodeId ? 'is-active' : ''}\\n            onClick={()