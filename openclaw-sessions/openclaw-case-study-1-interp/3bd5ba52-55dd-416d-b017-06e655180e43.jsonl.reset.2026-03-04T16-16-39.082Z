{"type":"message","id":"54fda643","parentId":"a8e63153","timestamp":"2026-03-04T11:28:04.868Z","message":{"role":"toolResult","toolCallId":"call_or8c0ZWbShfkJTwTpbSziXr1|fc_044be20a9efe26f90169a81731ab548191a1e9e65fd94738d7","toolName":"edit","content":[{"type":"text","text":"Successfully replaced text in visual-llm-ui/src/App.tsx."}],"details":{"diff":"   1 import './App.css'\n   2 import ReactFlow, { Background, Controls } from 'reactflow'\n   3 import 'reactflow/dist/style.css'\n-  4 import { useState } from 'react'\n   5 \n   6 import { ActivationsMatrix } from './components/ActivationsMatrix'\n-  7 import type { ActivationEntry } from './components/ActivationsMatrix'\n+  6 import { CircuitInspector } from './components/CircuitInspector'\n+  7 import { PatchControlPanel } from './components/PatchControlPanel'\n   8 import { PromptControl } from './components/PromptControl'\n+  9 import { RuntimeOverview } from './components/RuntimeOverview'\n+ 10 import { ScrubTimeline } from './components/ScrubTimeline'\n+ 11 import { useModelRuntime } from './runtime/modelRuntime'\n   9 \n  10 const featureCards = [\n  11   {\n  12     title: 'Activation patching lounge',\n  13     description:\n  14       'Show candidate neurons, layerwise activations, and patching experiments in real time with hooks for alternate prompts.',\n  15   },\n  16   {\n  17     title: 'Circuit topology canvas',\n  18     description:\n  19       'Compose directed graphs with React Flow to trace attribution through attention heads, MLPs, and residual streams.',\n  20   },\n  21   {\n  22     title: 'Causal scrubbing studio',\n  23     description:\n  24       'Replay interventions, swap on- and off-path activations, and compare logit trajectories for different scrubbing policies.',\n  25   },\n  26 ]\n  27 \n- 28 const runtimeTargets = [\n- 29   {\n- 30     title: 'M1 Pro + Metal',\n- 31     body: 'Quantized ONNX + Core ML exec repr for 4-bit Llama variants, keeping inference times under 80 ms per batch.',\n- 32   },\n- 33   {\n- 34     title: 'Browser-native engine',\n- 35     body: 'WebGPU + WebAssembly runtimes run distilled Transformers entirely client-side for demos.',\n- 36   },\n- 37   {\n- 38     title: 'Remote fallback',\n- 39     body: 'Optional cloud ops for heavier models, streaming scores back for blended interpretability workflows.',\n- 40   },\n- 41 ]\n- 42 \n- 43 const circuitNodes = [\n- 44   { id: '1', data: { label: 'Embedding' }, position: { x: 0, y: 0 } },\n- 45   { id: '2', data: { label: 'Layer 3 Attn 12' }, position: { x: 180, y: -20 } },\n- 46   { id: '3', data: { label: 'Layer 7 MLP 192' }, position: { x: 180, y: 120 } },\n- 47   { id: '4', data: { label: 'Residual Add' }, position: { x: 360, y: 40 } },\n- 48   { id: '5', data: { label: 'Logits' }, position: { x: 520, y: 40 } },\n- 49 ]\n- 50 \n- 51 const circuitEdges = [\n- 52   { id: 'e1-2', source: '1', target: '2', animated: true },\n- 53   { id: 'e1-3', source: '1', target: '3' },\n- 54   { id: 'e2-4', source: '2', target: '4' },\n- 55   { id: 'e3-4', source: '3', target: '4', animated: true },\n- 56   { id: 'e4-5', source: '4', target: '5' },\n- 57 ]\n- 58 \n- 59 const activationMetrics: ActivationEntry[] = [\n- 60   {\n- 61     neuron: 'Layer 2 attention head 5',\n- 62     impact: 12,\n- 63     note: 'Gate on positive sentiment.',\n- 64   },\n- 65   {\n- 66     neuron: 'Layer 7 MLP neuron 192',\n- 67     impact: -9,\n- 68     note: 'Key visual positional info.',\n- 69   },\n- 70   {\n- 71     neuron: 'Layer 9 residual stream',\n- 72     impact: 6,\n- 73     note: 'Surface-level commonsense bias.',\n- 74   },\n- 75 ]\n- 76 \n- 77 const activationHighlights = activationMetrics.map((metric) => ({\n- 78   label: metric.neuron,\n- 79   value: `${metric.impact > 0 ? '+' : ''}${metric.impact}% impact`,\n- 80   note: metric.note,\n- 81 }))\n- 82 \n  83 function App() {\n- 84   const [lastPrompt, setLastPrompt] = useState('')\n+ 32   const {\n+ 33     lastPrompt,\n+ 34     activations,\n+ 35     circuitNodes,\n+ 36     circuitEdges,\n+ 37     patchSummary,\n+ 38   } = useModelRuntime()\n  85 \n+ 40   const activationHighlights = activations.map((metric) => ({\n+ 41     label: metric.neuron,\n+ 42     value: `${metric.impact > 0 ? '+' : ''}${metric.impact}% impact`,\n+ 43     note: metric.note,\n+ 44   }))\n+ 45 \n  86   return (\n  87     <div className=\"app-shell\">\n  88       <header className=\"hero\">\n  89         <p className=\"eyebrow\">Browser-first interpretability</p>\n  90         <h1 data-testid=\"hero-heading\">Visualize transformer mechanics without lifting anything off your MacBook.</h1>\n  91         <p className=\"hero-subtitle\">\n  92           Activation patching, causal scrubbing, and circuit graphs layered over lightweight, quantized runtimes\n  93           keep the investigation on-device—perfect for M1-Pro-powered explorations.\n  94         </p>\n  95         <div className=\"hero-actions\">\n  96           <button className=\"primary\">Launch a live model session</button>\n  97           <button className=\"ghost\">Browse activation patches</button>\n  98         </div>\n  99       </header>\n 100 \n 101       <section className=\"prompt-panel\">\n-102         <PromptControl label=\"Inspect prompt\" onSubmit={(value) => setLastPrompt(value)} />\n+ 62         <PromptControl label=\"Inspect prompt\" onSubmit={useModelRuntime.getState().setPrompt} />\n 103         <p className=\"prompt-panel__status\">\n 104           {lastPrompt ? `Last prompt: ${lastPrompt}` : 'Run an input prompt to warm up the circuit scrubber.'}\n 105         </p>\n 106       </section>\n 107 \n 108       <section className=\"feature-grid\">\n 109         {featureCards.map((card) => (\n 110           <article key={card.title} className=\"feature-card\">\n 111             <h3>{card.title}</h3>\n 112             <p>{card.description}</p>\n 113           </article>\n 114         ))}\n 115       </section>\n 116 \n 117       <section className=\"panel-grid\">\n 118         <div className=\"panel activation-panel\">\n 119           <div className=\"panel-heading\">\n 120             <h2>Activation highlights</h2>\n 121             <span>Streaming logits from the last token</span>\n 122           </div>\n 123           <div className=\"activation-list\">\n 124             {activationHighlights.map((row) => (\n 125               <div key={row.label} className=\"activation-row\">\n 126                 <div>\n 127                   <p className=\"label\">{row.label}</p>\n 128                   <p className=\"note\">{row.note}</p>\n 129                 </div>\n 130                 <p className=\"value\">{row.value}</p>\n 131               </div>\n 132             ))}\n 133           </div>\n 134           <div className=\"activations-panel__matrix\">\n-135             <ActivationsMatrix activations={activationMetrics} />\n+ 95             <ActivationsMatrix activations={activations} />\n 136           </div>\n 137         </div>\n+ 98 \n 138         <div className=\"panel graph-panel\">\n 139           <div className=\"panel-heading\">\n 140             <h2>Circuit graph sketch</h2>\n 141             <span>Animate signal flow between attention heads and MLPs.</span>\n 142           </div>\n 143           <div className=\"graph-wrapper\">\n-144             <ReactFlow nodes={circuitNodes} edges={circuitEdges} fitView fitViewOptions={{ padding: 0.1 }}>\n+105             <ReactFlow\n+106               nodes={circuitNodes}\n+107               edges={circuitEdges}\n+108               fitView\n+109               fitViewOptions={{ padding: 0.1 }}\n+110               onNodeClick={(_, node) => useModelRuntime.getState().selectNode(node.id)}\n+111             >\n 145               <Background gap={18} size={1} />\n 146               <Controls showInteractive={false} />\n 147             </ReactFlow>\n 148           </div>\n+116           <CircuitInspector />\n 149         </div>\n 150       </section>\n 151 \n-152       <section className=\"runtime-grid\">\n-153         {runtimeTargets.map((target) => (\n-154           <article key={target.title} className=\"runtime-card\">\n-155             <h3>{target.title}</h3>\n-156             <p>{target.body}</p>\n-157           </article>\n-158         ))}\n+120       <section className=\"inspection-grid\">\n+121         <div className=\"panel patch-panel\">\n+122           <PatchControlPanel />\n+123         </div>\n+124         <div className=\"panel scrub-panel\">\n+125           <ScrubTimeline />\n+126         </div>\n 159       </section>\n+128 \n+129       <RuntimeOverview />\n 160     </div>\n 161   )\n 162 }\n 163 \n     ...","firstChangedLine":4},"isError":false,"timestamp":1772623684866}}
