estamp":1772623697958}}
{"type":"message","id":"641ac9e4","parentId":"8495b1d9","timestamp":"2026-03-04T11:28:19.771Z","message":{"role":"toolResult","toolCallId":"call_nui7Eml25ftVR0zn3E11bEnL|fc_044be20a9efe26f90169a817539d7881919d7ba477d3036742","toolName":"read","content":[{"type":"text","text":"import './App.css'\nimport ReactFlow, { Background, Controls } from 'reactflow'\nimport 'reactflow/dist/style.css'\n\nimport { ActivationsMatrix } from './components/ActivationsMatrix'\nimport { CircuitInspector } from './components/CircuitInspector'\nimport { PatchControlPanel } from './components/PatchControlPanel'\nimport { PromptControl } from './components/PromptControl'\nimport { RuntimeOverview } from './components/RuntimeOverview'\nimport { ScrubTimeline } from './components/ScrubTimeline'\nimport { useModelRuntime } from './runtime/modelRuntime'\n\nconst featureCards = [\n  {\n    title: 'Activation patching lounge',\n    description:\n      'Show candidate neurons, layerwise activations, and patching experiments in real time with hooks for alternate prompts.',\n  },\n  {\n    title: 'Circuit topology canvas',\n    description:\n      'Compose directed graphs with React Flow to trace attribution through attention heads, MLPs, and residual streams.',\n  },\n  {\n    title: 'Causal scrubbing studio',\n    description:\n      'Replay interventions, swap on- and off-path activations, and compare logit trajectories for different scrubbing policies.',\n  },\n]\n\nfunction App() {\n  const {\n    lastPrompt,\n    activations,\n    circuitNodes,\n    circuitEdges,\n    setPrompt,\n    selectNode,\n  } = useModelRuntime()\n\n  const activationHighlights = activations.map((metric) => ({\n    label: metric.neuron,\n    value: `${metric.impact > 0 ? '+' : ''}${metric.impact}% impact`,\n    note: metric.note,\n  }))\n\n  return (\n    <div className=\"app-shell\">\n      <header className=\"hero\">\n        <p className=\"eyebrow\">Browser-first interpretability</p>\n        <h1 data-testid=\"hero-heading\">Visualize transformer mechanics without lifting anything off your MacBook.</h1>\n        <p className=\"hero-subtitle\">\n          Activation patching, causal scrubbing, and circuit graphs layered over lightweight, quantized runtimes\n          keep the investigation on-device—perfect for M1-Pro-powered explorations.\n        </p>\n        <div className=\"hero-actions\">\n          <button className=\"primary\">Launch a live model session</button>\n          <button className=\"ghost\">Browse activation patches</button>\n        </div>\n      </header>\n\n      <section className=\"prompt-panel\">\n        <PromptControl label=\"Inspect prompt\" onSubmit={setPrompt} />\n        <p className=\"prompt-panel__status\">\n          {lastPrompt ? `Last prompt: ${lastPrompt}` : 'Run an input prompt to warm up the circuit scrubber.'}\n        </p>\n      </section>\n\n      <section className=\"feature-grid\">\n        {featureCards.map((card) => (\n          <article key={card.title} className=\"feature-card\">\n            <h3>{card.title}</h3>\n            <p>{card.description}</p>\n          </article>\n        ))}\n      </section>\n\n      <section className=\"panel-grid\">\n        <div className=\"panel activation-panel\">\n          <div className=\"panel-heading\">\n            <h2>Activation highlights</h2>\n            <span>Streaming logits from the last token</span>\n          </div>\n          <div className=\"activation-list\">\n            {activationHighlights.map((row) => (\n              <div key={row.label} className=\"activation-row\">\n                <div>\n                  <p className=\"label\">{row.label}</p>\n                  <p className=\"note\">{row.note}</p>\n                </div>\n                <p className=\"value\">{row.value}</p>\n              </div>\n            ))}\n          </div>\n          <div className=\"activations-panel__matrix\">\n            <ActivationsMatrix activations={activations} />\n          </div>\n        </div>\n\n        <div className=\"panel graph-panel\">\n          <div className=\"panel-heading\">\n            <h2>Circuit graph sketch</h2>\n            <span>Animate signal flow between attention heads and MLPs.</span>\n          </div>\n          <div className=\"graph-wrapper\">\n            <ReactFlow\n              nodes={circuitNodes}\n              edges={circuitEdges}\n              fitView\n              fitViewOptions={{ padding: 0.1 }}\n              onNodeClick={(_, node) => useModelRuntime.getState().selectNode(node.id)}\n            >\n              <Background gap={18} size={1} />\n              <Controls showInteractive={false} />\n            </ReactFlow>\n          </div>\n          <CircuitInspector />\n        </div>\n      </section>\n\n      <section className=\"inspection-grid\">\n        <div className=\"panel patch-panel\">\n          <PatchControlPanel />\n        </div>\n        <div className=\"panel scrub-panel\">\n          <ScrubTimeline />\n        </div>\n      </section>\n\n      <RuntimeOverview />\n    </div>\n  )\n}\n\nexport default App\n"}],"isError":false,"timestamp":1772623699768}}
