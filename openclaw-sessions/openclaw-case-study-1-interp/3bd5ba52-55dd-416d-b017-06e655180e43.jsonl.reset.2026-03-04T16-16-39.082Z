cross interventions.</h3>\n      </header>\n      <div className=\"scrub-list\">\n        {scrubRuns.map((run) => (\n          <article key={run.id} className=\"scrub-row\">\n            <div className=\"scrub-row__meta\">\n              <p className=\"scrub-row__label\">{run.label}</p>\n              <p className=\"scrub-row__summary\">{run.summary}</p>\n            </div>\n            <div className=\"scrub-row__bar\" aria-hidden>\n              <div\n                className=\"scrub-row__bar-fill\"\n                style={{\n                  width: `${Math.min(100, Math.abs(run.logitShift) * 12)}%`,\n                  background: run.logitShift >= 0 ? '#34d399' : '#fb7185',\n                }}\n              />\n            </div>\n            <div className=\"scrub-row__actions\">\n              <span className=\"scrub-row__value\">\n                {run.logitShift > 0 ? '+' : ''}\n                {run.logitShift}%\n              </span>\n              <button type=\"button\" onClick={() => runScrub(run.label)}>\n                Replay\n              </button>\n            </div>\n          </article>\n        ))}\n      </div>\n    </div>\n  )\n}\n"},"partialJson":"{\"path\":\"visual-llm-ui/src/components/ScrubTimeline.tsx\",\"content\":\"import { useModelRuntime } from '../runtime/modelRuntime'\\n\\nexport function ScrubTimeline() {\\n  const { scrubRuns, runScrub } = useModelRuntime()\\n  return (\\n    <div className=\\\"scrub-timeline\\\">\\n      <header>\\n        <p className=\\\"eyebrow\\\">Causal scrubbing</p>\\n        <h3>Track logit shifts across interventions.</h3>\\n      </header>\\n      <div className=\\\"scrub-list\\\">\\n        {scrubRuns.map((run) => (\\n          <article key={run.id} className=\\\"scrub-row\\\">\\n            <div className=\\\"scrub-row__meta\\\">\\n              <p className=\\\"scrub-row__label\\\">{run.label}</p>\\n              <p className=\\\"scrub-row__summary\\\">{run.summary}</p>\\n            </div>\\n       