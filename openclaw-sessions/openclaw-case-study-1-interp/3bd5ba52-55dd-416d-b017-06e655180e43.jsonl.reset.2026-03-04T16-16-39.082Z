{"type":"message","id":"380b7c01","parentId":"d894fb65","timestamp":"2026-03-04T11:25:30.869Z","message":{"role":"toolResult","toolCallId":"call_Jk5P36f5Q590iJFrFahqwv8b|fc_044be20a9efe26f90169a816aabb6081918a78685aa5fb23d0","toolName":"read","content":[{"type":"text","text":"\nexport interface ActivationEntry {\n  neuron: string\n  impact: number\n  note?: string\n}\n\nexport interface ActivationsMatrixProps {\n  activations: ActivationEntry[]\n}\n\nexport function ActivationsMatrix({ activations }: ActivationsMatrixProps) {\n  if (!activations.length) {\n    return <p role=\"status\">No activation data available yet.</p>\n  }\n\n  return (\n    <div className=\"activations-matrix\" role=\"table\" aria-label=\"Activation impacts\">\n      {activations.map((activation) => {\n        const trend = activation.impact >= 0 ? 'positive' : 'negative'\n        return (\n          <div\n            key={activation.neuron}\n            role=\"row\"\n            className={`activations-matrix__row activations-matrix__row--${trend}`}\n          >\n            <div className=\"activations-matrix__neuron\">{activation.neuron}</div>\n            <div className=\"activations-matrix__impact\" data-impact={activation.impact}>\n              {activation.impact > 0 ? '+' : ''}\n              {activation.impact}%\n            </div>\n            {activation.note && <div className=\"activations-matrix__note\">{activation.note}</div>}\n          </div>\n        )\n      })}\n    </div>\n  )\n}\n"}],"isError":false,"timestamp":1772623530867}}
